DATABASE_URL="postgresql://postgres:[SUA_SENHA_URL_ENCODED]@db.nqzdghxcscxemhkxfvzf.supabase.co:5432/postgres"
ADMIN_PASSWORD=admin123
TUNNEL_TOKEN=seu_token_cloudflare_aqui

# ─────────────────────────────────────────────────────────────
# MODELOS DE VISÃO COMPUTACIONAL
# ─────────────────────────────────────────────────────────────
# Modelo base (fallback PyTorch — usado enquanto o modelo treinado não está pronto)
YOLO_MODEL_PATH=yolov8n.pt
YOLO_SEG_MODEL_PATH=yolov8n-seg.pt

# Modelo fine-tuned (após treinamento com dataset de granja)
# Descomente e configure quando o treinamento estiver concluído:
# YOLO_SEG_MODEL_PATH=models/chikguard_best.pt

# ─────────────────────────────────────────────────────────────
# SAHI — DETECÇÃO DE MASSA EM ALTA RESOLUÇÃO (1080p)
# ─────────────────────────────────────────────────────────────
# Ativa o fatiamento de imagem para detectar pintinhos pequenos ao fundo
ENABLE_SAHI=true

# Tamanho de cada fatia em pixels (640 = ideal para YOLOv8 treinado em 640px)
# Para 1080p: gera ~8 tiles | Para 4K: gera ~18 tiles (muito pesado sem GPU)
SAHI_SLICE_SIZE=640

# Sobreposição entre tiles (20% garante que aves cortadas na borda apareçam em 2 tiles)
SAHI_OVERLAP=0.20

# Workers paralelos (4 = ideal para Mini PC Intel quad-core)
SAHI_WORKERS=4

# IoU do NMS global pós-fusão (elimina detecções duplicadas nas bordas dos tiles)
SAHI_NMS_IOU=0.45

# ─────────────────────────────────────────────────────────────
# ACELERAÇÃO DE HARDWARE (Intel Mini PC Linux — OpenVINO)
# ─────────────────────────────────────────────────────────────
# Backend de inferência: openvino | onnx | pytorch
# openvino = mais rápido em Intel (iGPU) | onnx = bom fallback | pytorch = desenvolvimento
INFERENCE_BACKEND=pytorch

# Caminho para o modelo OpenVINO (gerado por scripts/convert_to_openvino.py)
# Configure após executar a conversão:
# OPENVINO_MODEL_XML=models/chikguard_openvino_fp16/model.xml
OPENVINO_MODEL_XML=

# ─────────────────────────────────────────────────────────────
# DETECÇÃO — THRESHOLDS
# ─────────────────────────────────────────────────────────────
# Confiança mínima (0.25 = mais sensível, detecta pintinhos pequenos ao fundo)
# Suba para 0.40 se houver muitos falsos positivos após fine-tuning
DETECTION_CONF=0.25
DETECTION_IOU=0.45

# Tamanho de imagem para inferência direta (sem SAHI)
INFERENCE_IMGSZ=640

# Classe de ave alvo (só relevante para modelo COCO genérico)
BIRD_CLASS_NAME=bird

# ─────────────────────────────────────────────────────────────
# RASTREAMENTO
# ─────────────────────────────────────────────────────────────
# Algoritmo: bytetrack (padrão, melhor para multidões) | botsort
TRACKER_TYPE=bytetrack

# ─────────────────────────────────────────────────────────────
# CÂMERA
# ─────────────────────────────────────────────────────────────
# Backend de captura: dshow (Windows) | v4l2 (Linux) | any
CAMERA_BACKEND=v4l2
CAMERA_TARGET_FPS=30
STREAM_TARGET_FPS=15
SIM_VIDEO_PATH=video_granja.mp4
